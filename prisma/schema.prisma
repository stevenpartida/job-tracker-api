generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  companies    Company[]
  applications Application[]
  contacts     Contact[]
}

model Company {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  location     String?
  industry     String?
  websiteUrl   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  contacts     Contact[]
}

model Application {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  roleTitle         String
  status            String   @default("not_applied")
  priority          String   @default("medium")
  workModel         String   @default("on_site")
  jobUrl            String?
  techStack         String[]
  salaryMin         Int?
  salaryMax         Int?
  referralContactId String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Contact {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  role           String?
  email          String?
  linkedinUrl    String?
  connectionType String?
  notes          String?
  followUpDate   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}